# Server Configuration
PORT=3000

# JWT Configuration
# Generate secure random strings for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# MongoDB Configuration
MONGO_DB_URL=your-mongodb-connection-string-here

# Email Configuration (для разработки с Maildev)
MAILDEV_HOST=localhost
MAILDEV_PORT=1025

# Email Configuration (для продакшена)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# EMAIL_FROM=noreply@example.com

# Frontend URL (для ссылок в email)
FRONTEND_URL=http://localhost:3001
